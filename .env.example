# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# football-data.org
FOOTBALL_API_KEY=your-api-key-here

# Server
PORT=3000

# Cron schedule — how often to sync
# Examples:
#   0 * * * *     every hour
#   */30 * * * *  every 30 minutes
#   0 6 * * *     every day at 6am
# See https://crontab.guru
CRON_SCHEDULE=0 * * * *
