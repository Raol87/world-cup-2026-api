# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# football-data.org
FOOTBALL_API_KEY=your-api-key-here

# CORS — comma-separated list of origins allowed to call the read API
# This should be the domain of the Vue app your component is embedded in
# e.g. ALLOWED_ORIGINS=https://parentapp.com,https://staging.parentapp.com
ALLOWED_ORIGINS=https://parentapp.com

# Server
PORT=3000

# Cron schedule — how often to sync
# Examples:
#   0 * * * *     every hour
#   */30 * * * *  every 30 minutes
#   0 6 * * *     every day at 6am
# See https://crontab.guru
CRON_SCHEDULE=0 * * * *
